{
  "name": "cloudnote-test",
  "version": "1.0.0",
  "description": "A cloud note-taking app built on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir .wrangler/build",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "test": "vitest run --passWithNoTests",
    "format": "prettier --write ."
  },
  "dependencies": {
    "hono": "^4.5.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "wrangler": "^4.68.0"
  },
  "engines": {
    "node": ">=18"
  }
}
